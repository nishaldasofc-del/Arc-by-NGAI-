rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (optional)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - lastLoginAt: timestamp (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (!('email' in data) || data.email == null || data.email is string) &&
             (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
             (!('lastLoginAt' in data) || data.lastLoginAt == null || data.lastLoginAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.uid == resource.data.uid;
    }
  }
}
